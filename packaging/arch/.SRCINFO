pkgbase = aurascan
	pkgdesc = AI-assisted safety and recovery layer for Arch-family systems
	pkgver = 0.6.0
	pkgrel = 1
	url = https://github.com/crizzler/AuraScan
	install = aurascan.install
	arch = any
	license = MIT
	checkdepends = python-pytest
	makedepends = python-build
	makedepends = python-installer
	makedepends = python-setuptools
	makedepends = python-wheel
	depends = python
	depends = hicolor-icon-theme
	optdepends = clamav: AV signature scanning through clamscan
	optdepends = gnupg: explicit deep-static signature verification
	optdepends = pacman: local package database, upgrade preflight, and vercmp support
	optdepends = base-devel: makepkg wrapper workflows
	optdepends = paru: AUR update context for aurascan upgrade
	optdepends = yay: AUR update context for aurascan upgrade
	optdepends = shelly: optional Shelly update handoff for aurascan upgrade
	optdepends = python-pyqt6: AuraScan Updater tray applet
	optdepends = pacman-contrib: bounded package-cache cleanup for incident recovery
	optdepends = mkosi: build the optional local AuraScan Recovery UKI
	optdepends = systemd: systemd-boot integration and recovery runtime support
	optdepends = systemd-ukify: validate and assemble the optional recovery UKI
	optdepends = arch-install-scripts: run bounded package and repair commands in a recovery target
	optdepends = sbctl: sign the recovery UKI when Secure Boot is enabled
	optdepends = networkmanager: Ethernet, tethering, and Wi-Fi in AuraScan Recovery
	optdepends = iwd: WPA2/WPA3 Wi-Fi backend for AuraScan Recovery
	optdepends = cryptsetup: unlock LUKS2 recovery targets
	optdepends = lvm2: discover LVM recovery targets
	optdepends = mdadm: discover mdraid recovery targets
	optdepends = btrfs-progs: Btrfs diagnosis and snapshot recovery
	optdepends = snapper: snapshot test and confirmed restore workflows
	optdepends = xfsprogs: read-only XFS recovery diagnostics
